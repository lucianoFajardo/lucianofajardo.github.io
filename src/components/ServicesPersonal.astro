---
import {services} from '../lib/models/services-log.ts';
---

<section id="services" class="mt-20 mb-10 w-full max-w-5xl mx-auto px-4 font-['Noto_Sans_JP']">
  <h2
        class="font-bold mb-8 flex items-center gap-3 font-['DotGothic16'] text-2xl text-pink-100"
    >
        <span
            class="bg-pink-500/10 text-pink-500 border border-pink-500/30 px-2 py-1 rounded text-sm text-neon font-['Fira_Code'] tracking-widest"
            >CMD</span
        > ls ./services
    </h2>
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    {services.map(service => (
      <div class="flex flex-col gap-3 group">
        <div class="flex items-center gap-3">
          <span 
            class="text-pink-500 group-hover:text-pink-400 group-hover:shadow-[0_0_10px_rgba(236,72,153,0.3)] transition-all rounded-full" 
            set:html={service.icon} 
          />
          <h3 class="text-xl font-bold text-pink-50 drop-shadow-[0_0_5px_rgba(236,72,153,0.3)]">
            {service.title}
          </h3>
        </div>
        
        <!-- Descripción -->
        <p 
          class="text-pink-100/70 text-sm leading-relaxed" 
          set:html={service.description}
        />
      </div>
    ))}
  </div>
</section>