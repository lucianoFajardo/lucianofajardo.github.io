---
// SakuraBackground.astro
---

<!-- SVG del Árbol (Rama estilo Japonés) -->
<div class="fixed top-0 right-0 w-full h-full pointer-events-none -z-20 overflow-hidden opacity-40">
  <!-- Agregando un brillo sutil (drop-shadow neon) y modificando color a fucsia oscuro -->
  <svg class="absolute top-[-5%] right-[-5%] w-2/3 md:w-1/2 lg:w-1/3 stroke-pink-500/20 fill-[#2A102A] drop-shadow-[0_0_15px_rgba(236,72,153,0.15)]" viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg">
    <!-- Una silueta muy simplificada y optimizada de ramas -->
    <path d="M 500 0 Q 350 50 250 150 T 100 250 Q 80 300 0 320 Q 50 280 150 220 T 300 120 Q 400 40 500 0 Z"></path>
    <path d="M 300 120 Q 200 150 150 220 Q 120 180 80 150 Q 150 150 200 100 Q 250 80 300 120 Z"></path>
    <path d="M 400 30 Q 350 100 300 120 Q 250 180 200 200 Q 150 180 100 120 Q 180 140 250 100 Q 300 50 400 30 Z"></path>
  </svg>
  
  <svg class="absolute bottom-[-10%] left-[-10%] w-3/4 md:w-1/2 lg:w-1/3 stroke-pink-500/20 fill-[#2A102A] drop-shadow-[0_0_15px_rgba(236,72,153,0.15)]" style="transform: scaleX(-1); opacity: 0.8;" viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg">
    <!-- Otra de lado izquierdo -->
    <path d="M 500 500 Q 350 400 200 300 T 50 150 Q 20 100 0 50 Q 50 100 150 200 T 350 350 Q 450 450 500 500 Z"></path>
    <path d="M 350 350 Q 250 400 150 350 Q 180 250 250 300 Q 300 320 350 350 Z"></path>
  </svg>
</div>

<!-- Canvas para partículas Sakura (Alto rendimiento) -->
<canvas id="sakura-canvas" class="fixed top-0 left-0 w-full h-full pointer-events-none -z-10 opacity-60"></canvas>

<script>
  // Implementación ligera usando Canvas para mantener el rendimiento al máximo
  const canvas = document.getElementById("sakura-canvas") as HTMLCanvasElement;
  
  if (canvas) {
    const ctx = canvas.getContext("2d");
    let animationFrameId: number;
    let petals: Petal[] = [];
    
    // Configuraciones de rendimiento (Reducir conteo = mejor rendimiento)
    const PETAL_COUNT = 30; 

    // Ajustar el tamaño del canvas
    const resizeCanvas = () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    };
    
    window.addEventListener("resize", resizeCanvas);
    resizeCanvas();

    class Petal {
      x: number;
      y: number;
      w: number;
      h: number;
      opacity: number;
      speedX: number;
      speedY: number;
      rotation: number;
      rotationSpeed: number;

      constructor() {
        this.x = Math.random() * canvas.width;
        this.y = Math.random() * canvas.height - canvas.height;
        this.w = 5 + Math.random() * 5;     // Ancho del pétalo
        this.h = 10 + Math.random() * 10;   // Alto del pétalo
        this.opacity = 0.2 + Math.random() * 0.5; // Pétalos tenues para no distraer
        this.speedX = Math.random() * 1 - 0.5;
        this.speedY = 0.5 + Math.random() * 1.5;
        this.rotation = Math.random() * 360;
        this.rotationSpeed = Math.random() * 2 - 1;
      }

      update() {
        this.x += this.speedX;
        this.y += this.speedY;
        this.rotation += this.rotationSpeed;

        // Resetear si sale fuera de pantalla para reutilizar el objeto (bueno para el rendimiento)
        if (this.y > canvas.height + this.h || this.x > canvas.width + this.w || this.x < -this.w) {
          this.x = Math.random() * canvas.width;
          this.y = -this.h;
        }
      }

      draw(ctx: CanvasRenderingContext2D) {
        ctx.save();
        ctx.translate(this.x, this.y);
        ctx.rotate((this.rotation * Math.PI) / 180);
        ctx.globalAlpha = this.opacity;

        // Efecto glow neon suave (sin sobrecargar el renderizado)
        ctx.shadowBlur = 8;
        ctx.shadowColor = "#ec4899"; // Rosa neon oscuro brillando

        // Dibujar forma de pétalo Sakura (con muesca) en lugar de elipse simple
        ctx.beginPath();
        // Color base del pétalo: Rosa pastel sutil
        ctx.fillStyle = "#fbcfe8"; 
        
        ctx.moveTo(0, this.h / 2); // Punta inferior
        ctx.quadraticCurveTo(this.w / 2, this.h / 4, this.w / 2, -this.h / 3);
        ctx.quadraticCurveTo(this.w / 4, -this.h / 2, 0, -this.h / 4); // Muesca superior (cleft)
        ctx.quadraticCurveTo(-this.w / 4, -this.h / 2, -this.w / 2, -this.h / 3);
        ctx.quadraticCurveTo(-this.w / 2, this.h / 4, 0, this.h / 2);
        
        ctx.fill();
        
        ctx.restore();
      }
    }

    // Inicializar
    for (let i = 0; i < PETAL_COUNT; i++) {
        petals.push(new Petal());
    }

    // Ciclo de animación
    const animate = () => {
      ctx!.clearRect(0, 0, canvas.width, canvas.height);
      petals.forEach(petal => {
        petal.update();
        petal.draw(ctx!);
      });
      animationFrameId = requestAnimationFrame(animate);
    };

    animate();
    
    // Limpieza al desmontar (si fuera necesario en SPA, Astro no lo requiere estrictamente excepto en view transitions)
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animationFrameId);
    }, { once: true });
  }
</script>